{
  "name": "math",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --port 3000 --console index.html",
    "build": "bun run typecheck && bun run scripts/build.ts",
    "check": "bun run lint && bun run test && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "preview": "bun run scripts/preview.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/howler": "^2.2.12",
    "bun-plugin-tailwind": "^0.1.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "playwright": "^1.52.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "ecspresso": "^0.18.0",
    "howler": "^2.2.4",
    "typescript-eslint": "^8.59.2"
  }
}
